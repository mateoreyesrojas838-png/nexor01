{
  "name": "nexor-desktop",
  "version": "1.0.0",
  "description": "Nexor WhatsApp Extractor - Desktop app for exporting WhatsApp contacts to Nexor CRM",
  "main": "main.js",
  "author": "Nexor",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "package:win": "electron-packager . \"Nexor WhatsApp Extractor\" --platform=win32 --arch=x64 --out=dist --overwrite --icon=icon.png",
    "package:mac": "electron-packager . \"Nexor WhatsApp Extractor\" --platform=darwin --arch=x64 --out=dist --overwrite --icon=icon.png",
    "package:linux": "electron-packager . \"Nexor WhatsApp Extractor\" --platform=linux --arch=x64 --out=dist --overwrite --icon=icon.png"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.nexor.whatsapp-extractor",
    "productName": "Nexor WhatsApp Extractor",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "app.js",
      "extractor.js",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
